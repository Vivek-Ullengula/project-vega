{
  "agent_id": "vega_binding_authority_bot",
  "version": "1.0",
  "orchestration_framework": "strands",
  "prompt_template_id": "vega_binding_authority_bot",
  "model_profile": {
    "provider": "bedrock",
    "model_id": "openai.gpt-oss-safeguard-120b",
    "temperature": 0.0,
    "max_tokens": 2048
  },
  "retrieval_profile": {
    "provider": "bedrock_knowledge_base",
    "enabled": true,
    "knowledge_base_ids": [
      "2KMBSFAGGS"
    ],
    "reranking_enabled": true,
    "citations_required": true
  },
  "memory_profile": {
    "provider": "agentcore_memory",
    "enabled": true,
    "memory_id": "vega_binding_authority_bot_memory",
    "memory_scope": "agent_user",
    "retention_days": 90,
    "ltm_strategies": [
      "SEMANTIC",
      "SUMMARIZATION"
    ]
  },
  "session_profile": {
    "provider": "s3",
    "bucket": "vega-binding-authority",
    "prefix": "sessions/",
    "conversation_window_size": 10
  },
  "tool_permissions": [
    {
      "tool_id": "search_manuals",
      "action_class": "read",
      "allowed_roles": [
        "underwriter",
        "agent"
      ]
    }
  ],
  "guardrail_profile": {
    "guardrail_id": "",
    "guardrail_version": "DRAFT",
    "input_check_enabled": true,
    "output_check_enabled": true
  },
  "observability_profile": {
    "provider": "cloudwatch",
    "emit_metrics": true,
    "emit_traces": true,
    "log_raw_prompt": false,
    "log_raw_response": false
  }
}